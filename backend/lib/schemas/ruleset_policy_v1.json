{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ssge://schemas/ruleset_policy_v1.json",
  "title": "SSGE RuleSet Policy Schema v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyVersion", "ruleSetVersion", "createdAt", "status", "defaults", "rules"],
  "properties": {
    "policyVersion": {
      "type": "string",
      "pattern": "^1\\.0$",
      "description": "Policy schema version."
    },
    "ruleSetVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Frozen ruleset version identifier (e.g., v0.1.0)."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "retired", "shadow"],
      "description": "Ruleset lifecycle state."
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domains": { "type": "array", "items": { "type": "string" } },
        "adapters": { "type": "array", "items": { "type": "string" } }
      },
      "description": "Optional scope limits for this ruleset."
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseConfidence", "lossAlpha", "thresholds"],
      "properties": {
        "baseConfidence": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 },
        "lossAlpha": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.6 },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["warnLoss", "reviewLoss", "rejectLoss"],
          "properties": {
            "warnLoss": { "type": "number", "minimum": 0, "maximum": 1 },
            "reviewLoss": { "type": "number", "minimum": 0, "maximum": 1 },
            "rejectLoss": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "actions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "onWarn": { "type": "string", "enum": ["noop", "flag", "penalize"] },
            "onReview": { "type": "string", "enum": ["flag", "penalize", "block"] },
            "onReject": { "type": "string", "enum": ["block"] }
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/rule" }
    }
  },
  "definitions": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ruleId", "title", "severity", "enabled", "when", "then"],
      "properties": {
        "ruleId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "enabled": { "type": "boolean" },
        "mode": {
          "type": "string",
          "enum": ["active", "shadow"],
          "default": "active",
          "description": "shadow means log only, do not enforce."
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "domains": { "type": "array", "items": { "type": "string" } },
            "adapters": { "type": "array", "items": { "type": "string" } }
          }
        },
        "when": { "$ref": "#/definitions/condition" },
        "then": { "$ref": "#/definitions/actionSet" },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requireEvidenceFields": {
              "type": "array",
              "items": { "type": "string" }
            },
            "minEvidenceConfidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minSupport": { "type": "integer", "minimum": 0 },
            "minPrecision": { "type": "number", "minimum": 0, "maximum": 1 },
            "minLift": { "type": "number", "minimum": 0 }
          },
          "description": "Offline mining quality gates (for documentation & governance)."
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op"],
      "properties": {
        "op": {
          "type": "string",
          "enum": ["all", "any", "not", "eq", "ne", "gt", "gte", "lt", "lte", "exists", "missing", "in", "between", "regex"]
        },
        "path": { "type": "string", "description": "JSON pointer-like path (e.g., $.loss.avgLossScore)" },
        "value": {},
        "values": { "type": "array", "items": {} },
        "min": {},
        "max": {},
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/definitions/condition" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "op": { "const": "all" } } },
          "then": { "required": ["conditions"] }
        },
        {
          "if": { "properties": { "op": { "const": "any" } } },
          "then": { "required": ["conditions"] }
        },
        {
          "if": { "properties": { "op": { "const": "not" } } },
          "then": { "required": ["conditions"] }
        },
        {
          "if": {
            "properties": {
              "op": { "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "exists", "missing", "regex"] }
            }
          },
          "then": { "required": ["path"] }
        },
        {
          "if": { "properties": { "op": { "enum": ["eq", "ne", "gt", "gte", "lt", "lte", "regex"] } } },
          "then": { "required": ["value"] }
        },
        {
          "if": { "properties": { "op": { "const": "in" } } },
          "then": { "required": ["path", "values"] }
        },
        {
          "if": { "properties": { "op": { "const": "between" } } },
          "then": { "required": ["path", "min", "max"] }
        }
      ]
    },
    "actionSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actions"],
      "properties": {
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/action" }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["set_status", "penalize_confidence", "require_review", "block_output", "emit_trace", "require_fields"]
        },
        "value": {},
        "fields": { "type": "array", "items": { "type": "string" } },
        "message": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "set_status" } } },
          "then": { "required": ["value"], "properties": { "value": { "type": "string", "enum": ["ok", "needs_review", "reject", "partial"] } } }
        },
        {
          "if": { "properties": { "type": { "const": "penalize_confidence" } } },
          "then": { "required": ["value"], "properties": { "value": { "type": "number", "minimum": 0, "maximum": 1 } } }
        },
        {
          "if": { "properties": { "type": { "const": "require_fields" } } },
          "then": { "required": ["fields"] }
        }
      ]
    }
  }
}